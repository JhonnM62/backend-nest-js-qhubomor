  fechaInicio       DateTime @map("FechaInicio") @db.Date
  fechaFin          DateTime @map("FechaFin") @db.Date
  totalTurnos       Int      @default(0) @map("TotalTurnos")
  totalBruto        Decimal  @default(0) @map("TotalBruto") @db.Money
  totalDescuentos   Decimal  @default(0) @map("TotalDescuentos") @db.Money
  totalNeto         Decimal  @default(0) @map("TotalNeto") @db.Money
  estado            String   @default("PENDIENTE") @map("Estado")
  observaciones     String?  @map("Observaciones")
  pdfUrl            String?  @map("PdfUrl")
  creadoPor         String   @map("CreadoPor")
  turnosDetalle     Json?    @map("TurnosDetalle")
  descuentosDetalle Json?    @map("DescuentosDetalle")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  usuario           Usuarios @relation(fields: [usuarioId], references: [IDusuarios], onDelete: Cascade)

