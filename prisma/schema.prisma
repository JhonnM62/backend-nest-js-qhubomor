}

model Turnos {
  IDturno               String               @id @default(cuid()) @map("IDturno")
  usuarioId             String               @map("UsuarioId")
  fecha                 DateTime             @map("Fecha") @db.Date
  horaEntrada           DateTime             @map("HoraEntrada")
  horaSalida            DateTime?            @map("HoraSalida")
  fotoEntrada           String?              @map("FotoEntrada")
  latitud               Float?               @map("Latitud")
  longitud              Float?               @map("Longitud")
  distanciaMetros       Float?               @map("DistanciaMetros")
  dentroGeocerca        Boolean              @default(false) @map("DentroGeocerca")
  ceno                  Boolean?             @map("Ceno")
  valorTurno            Decimal              @default(0) @map("ValorTurno") @db.Money
  estado                String               @default("ACTIVO") @map("Estado")
  observacion           String?              @map("Observacion")
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  dentroGeocercaSalida  Boolean?             @map("DentroGeocercaSalida")
  distanciaMetrosSalida Float?               @map("DistanciaMetrosSalida")
  fotoSalida            String?              @map("FotoSalida")
  latitudSalida         Float?               @map("LatitudSalida")
  longitudSalida        Float?               @map("LongitudSalida")
  descuentos            DescuentosEmpleado[]
  usuario               Usuarios             @relation(fields: [usuarioId], references: [IDusuarios], onDelete: Cascade)

  @@map("TURNOS")
}

model DescuentosEmpleado {
  IDdescuento String   @id @default(cuid()) @map("IDdescuento")
  usuarioId   String   @map("UsuarioId")
  turnoId     String?  @map("TurnoId")
  loteId      String?  @map("LoteId")
  fecha       DateTime @map("Fecha")
  concepto    String   @map("Concepto")
  descripcion String   @map("Descripcion")
  valor       Decimal  @map("Valor") @db.Money
  estado      String   @default("PENDIENTE") @map("Estado")
  creadoPor   String   @map("CreadoPor")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  turno       Turnos?  @relation(fields: [turnoId], references: [IDturno])
  usuario     Usuarios @relation(fields: [usuarioId], references: [IDusuarios], onDelete: Cascade)

  @@map("DESCUENTOS_EMPLEADO")
}

model Liquidaciones {
  IDliquidacion     String   @id @default(cuid()) @map("IDliquidacion")
